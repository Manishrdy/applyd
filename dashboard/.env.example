# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# Data paths (relative to dashboard/)
DB_PATH=./data/applyd.db
CACHE_DIR=./cache/parquet

# Upstream
MANIFEST_URL=https://storage.stapply.ai/jobhive/v1/manifest.json
HTTP_TIMEOUT_SECONDS=120
DOWNLOAD_CONCURRENCY=4

# Ingestion
INGEST_HOUR_UTC=11               # daily cron hour
ROLLING_WINDOW_DAYS=30           # prune COALESCE(posted_at, first_seen_at) older than this
INGEST_BATCH_SIZE=10000          # pyarrow batch rows

# Query defaults
DEFAULT_COUNTRY=US
DEFAULT_POSTED_HOURS=24
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=100

APPLYD_BACKUP_TOKEN=""

# Expired-job detection lifecycle (services/job_lifecycle.py + services/verifier.py)
#
# Two-stage kill switches:
#   EXPIRED_DETECTION_ENABLED       — master on/off. False = lifecycle is
#                                     completely dormant (signals not collected).
#   VERIFIER_AUTO_MARKING_ENABLED   — when False (the safe default), the
#                                     verifier checks jobs and writes to
#                                     job_verification_log, but jobs never
#                                     auto-flip to verification_status='expired'.
#                                     Flip to true once you've observed
#                                     matcher accuracy for a couple of weeks.
EXPIRED_DETECTION_ENABLED=true
VERIFIER_AUTO_MARKING_ENABLED=false

# Sweep cadence — how often every active job is re-checked.
# Default: every active job is visited ~once every 1 day.
VERIFIER_SWEEP_DAYS=1
VERIFIER_SWEEP_INTERVAL_MINUTES=10    # how often the sweep tick fires
VERIFIER_SWEEP_ALL_ACTIVE=true        # true = walk the whole corpus continuously
                                      # false = only check jobs older than sweep_days

# HTTP behaviour for the verifier
VERIFIER_PER_HOST_CONCURRENCY=4       # parallel checks per ATS host
VERIFIER_GLOBAL_CONCURRENCY=16        # parallel checks across all hosts
VERIFIER_REQUEST_TIMEOUT_SECONDS=20   # per-check timeout

# Suspected pool drain (event-driven verifications)
VERIFIER_SUSPECTED_INTERVAL_MINUTES=5
VERIFIER_SUSPECTED_BATCH=50

# Sweep batch size — leave blank to auto-compute as
# corpus / (sweep_days * 24h / sweep_interval_minutes).
VERIFIER_SWEEP_BATCH_SIZE=

# Per-(ats_type, hour) circuit breaker — halts auto-expires for an ATS
# if it produces more than this many expirations in one hour bucket.
VERIFIER_CIRCUIT_BREAKER_THRESHOLD=25

# User-report rate limits (POST /api/jobs/{id}/report)
REPORT_RATE_LIMIT_PER_DAY=20
REPORT_RATE_LIMIT_PER_COMPANY_PER_WEEK=5