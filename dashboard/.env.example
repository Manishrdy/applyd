# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# Data paths (relative to dashboard/)
DB_PATH=./data/applyd.db
CACHE_DIR=./cache/parquet

# Upstream
MANIFEST_URL=https://storage.stapply.ai/jobhive/v1/manifest.json
HTTP_TIMEOUT_SECONDS=120
DOWNLOAD_CONCURRENCY=4

# Ingestion
INGEST_HOUR_UTC=11               # daily cron hour
ROLLING_WINDOW_DAYS=30           # prune COALESCE(posted_at, first_seen_at) older than this
INGEST_BATCH_SIZE=10000          # pyarrow batch rows

# Query defaults
DEFAULT_COUNTRY=US
DEFAULT_POSTED_HOURS=24
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=100
